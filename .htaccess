RewriteEngine On

#RewriteCond %{REQUEST_URI} !^/dev/?(.*)$ [NC]

# Apply rules only if the request contains /infopedia
# RewriteCond %{REQUEST_FILENAME} !-f
#RewriteRule ^()$ /echo.php?request0=$1 [QSA,L]
#RewriteRule ^(/?)$ echo.php?request1=$1 [QSA,L]
#RewriteRule ^/?(infopedia/)?dev/?$ /dev/infopedia.html [QSA,L]
RewriteRule ^/?$ infopedia.php?topic=/ [QSA,L]
RewriteRule ^/?InfoPedia_Steckbrief.pdf$ download.php?file=InfoPedia_Steckbrief.pdf [QSA,L]
RewriteRule ^/?(infopedia/(dev/)?)?InfoPedia.apk$ download.php?file=InfoPedia.apk [QSA,L]
RewriteRule ^/?(infopedia/(dev/)?)?fayf.apk$ download.php?file=fayf.apk [QSA,L]
RewriteRule ^/?(infopedia/(dev/)?)?fayf.aab$ download.php?file=fayf.aab [QSA,L]
#RewriteRule ^/?download/?$ download.php [QSA,L]
#
RewriteRule ^/?(dev/)?(entries)(/get)?/?$ read.php?type=entry&op=get [QSA,L]
RewriteRule ^/?(dev/)?(votes)(/get)?/?$ read.php?type=vote&op=get [QSA,L]
RewriteRule ^/?(dev/)?(entry|vote)(/get)?/?$ read.php?type=$2&op=get [QSA,L]
RewriteRule ^/?(dev/)?(entry|vote)/add/?$ upload.php?type=$2&op=add [QSA,L]
RewriteRule ^/?(dev/)?(dump)(/add)?/?$ upload.php?type=$2&op=add [QSA,L]
#
RewriteRule ^/?(dev/)?favicon.ico favicon.ico [NC,L]
RewriteRule ^/?(dev/)?favicon-16x16\.png favicon-16x16.png [NC,L]
RewriteRule ^/?(dev/)?favicon-32x32\.png favicon-32x32.png [NC,L]
RewriteRule ^/?(dev/)?apple-touch-icon\.png apple-touch-icon.png [NC,L]
RewriteRule ^/?(dev/)?android-chrome-192x192\.png android-chrome-192x192.png [NC,L]
RewriteRule ^/?(dev/)?android-chrome-512x512\.png android-chrome-512x512.png [NC,L]
RewriteRule ^/?(dev/)?site.webmanifest site.webmanifest [NC,L]
RewriteRule ^/?(dev/)?robots.txt robots.txt [NC,L]
RewriteRule ^/?(dev/)?assets/(app_expl_[a-zA-Z0-9_\-]+\.(png|gif)) assets/$2 [NC,L]
RewriteRule ^/?(dev/)?assets/(icon(s8)?[_-][a-zA-Z0-9_\-]+\.(svg)) assets/$2 [NC,L]


#
# catch-all rule for other requests
# -- https://serverfault.com/questions/241907/rewriterules-not-stopping-with-last-flag
RewriteCond %{REQUEST_URI} !^/(infopedia/)?(dev/)?assets/icon(s8)?[_-][a-zA-Z0-9_\-]+\.(svg)$
RewriteCond %{REQUEST_URI} !^/(infopedia/)?(dev/)?assets/app_expl_[a-zA-Z0-9_\-]+\.(png|gif)$
RewriteCond %{REQUEST_URI} !^/(infopedia/)?(dev/)?(favicon\.ico|favicon-16x16\.png|favicon-32x32\.png|apple-touch-icon\.png|android-chrome-192x192\.png|android-chrome-512x512\.png|site\.webmanifest|robots\.txt)$
RewriteCond %{REQUEST_URI} !^/(infopedia/)?(dev/)?(echo|read|infopedia|upload|statistic|download)\.php$
RewriteCond %{REQUEST_URI} !^/(infopedia/)?(dev/)?(styles|styles_statistic)\.css$
RewriteCond %{REQUEST_URI} !^/(infopedia/)?(dev/)?InfoPedia.apk$
# RewriteRule ^(.*)$ echo.php?request_catch_all=$1 [QSA,L]
#RewriteRule ^(.*)$ infopedia.php?topic=/ [QSA,L]
RewriteRule ^(.*)$ infopedia.php?topic=/&missed=$1 [QSA,L]
# End of .htaccess